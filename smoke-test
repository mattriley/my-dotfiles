#!/usr/bin/env bash
set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MODULES_DIR="$SCRIPT_DIR/src/bash/modules"

echo "Smoke test: loading bash modules (no $HOME writes)"

if [ ! -d "$MODULES_DIR" ]; then
  echo "FAIL: modules directory not found: $MODULES_DIR" >&2
  exit 1
fi

failures=0

function fail {
  local message="$1"
  echo "FAIL: $message" >&2
  failures=$((failures+1))
}

function expect_eq {
  local actual="$1"
  local expected="$2"
  local message="$3"
  [ "$actual" = "$expected" ] || fail "$message: $actual"
}

function expect_contains {
  local haystack="$1"
  local needle="$2"
  local message="$3"
  [[ "$haystack" == *"$needle"* ]] || fail "$message: $haystack"
}

function expect_not_contains {
  local haystack="$1"
  local needle="$2"
  local message="$3"
  [[ "$haystack" != *"$needle"* ]] || fail "$message: $haystack"
}

function expect_line_count {
  local haystack="$1"
  local pattern="$2"
  local expected_count="$3"
  local message="$4"
  local actual_count
  actual_count="$(printf '%s\n' "$haystack" | grep -c "$pattern")"
  [ "$actual_count" -eq "$expected_count" ] || fail "$message: $haystack"
}

function make_temp_home {
  mktemp -d /tmp/my-dotfiles-home.XXXXXX
}

function setup_temp_profile_home {
  local tmp_home="$1"
  local shell_name="$2"

  cp "$SCRIPT_DIR/src/bash/profiles/default/.bashrc" "$tmp_home/.bashrc"
  if [ "$shell_name" = "bash" ]; then
    cp "$SCRIPT_DIR/src/bash/profiles/default/.bash_profile" "$tmp_home/.bash_profile"
  else
    cp "$SCRIPT_DIR/src/bash/profiles/default/.zprofile" "$tmp_home/.zprofile"
    cp "$SCRIPT_DIR/src/bash/profiles/default/.zshrc" "$tmp_home/.zshrc"
  fi
}

function run_bash_profile {
  local tmp_home="$1"
  shift
  HOME="$tmp_home" bash "$@" 2>&1
}

function run_zsh_profile {
  local tmp_home="$1"
  shift
  HOME="$tmp_home" zsh "$@" 2>&1
}

function assert_bash_profile_noninteractive_clean {
  local tmp_home
  local out

  echo "OK: .bash_profile degrades cleanly when modules are unavailable"
  tmp_home="$(make_temp_home)"
  setup_temp_profile_home "$tmp_home" "bash"
  out="$(TERM='' run_bash_profile "$tmp_home" --noprofile --norc --rcfile "$tmp_home/.bash_profile" -i -c exit)"
  rm -rf "$tmp_home"
  expect_not_contains "$out" "command not found" ".bash_profile should not call missing helper functions"
  expect_not_contains "$out" "Shell: bash" ".bash_profile should stay quiet in non-interactive shells"
}

function assert_bash_profile_requires_bashrc {
  local tmp_home
  local out

  echo "OK: .bash_profile fails clearly when .bashrc is missing"
  tmp_home="$(make_temp_home)"
  cp "$SCRIPT_DIR/src/bash/profiles/default/.bash_profile" "$tmp_home/.bash_profile"
  # shellcheck disable=SC2016
  out="$(run_bash_profile "$tmp_home" --noprofile --norc -i -c 'source "$HOME/.bash_profile"; exit')"
  rm -rf "$tmp_home"
  expect_contains "$out" "Error: missing required file: $tmp_home/.bashrc" ".bash_profile should require .bashrc"
}

function assert_bash_profile_loads_modules {
  local tmp_home
  local out

  echo "OK: configured BASH_MODULES loads repo modules"
  tmp_home="$(make_temp_home)"
  ln -s "$SCRIPT_DIR/src/bash/profiles/default/.bash_profile" "$tmp_home/.bash_profile"
  cp "$SCRIPT_DIR/src/bash/profiles/default/.bashrc" "$tmp_home/.bashrc"
  out="$(run_bash_profile "$tmp_home" --rcfile "$tmp_home/.bash_profile" -i -c 'declare -f prompt.dev >/dev/null && echo prompt_loaded; declare -f node.nvm.setup >/dev/null && echo nvm_loaded; exit')"
  rm -rf "$tmp_home"
  expect_contains "$out" "prompt_loaded" "configured BASH_MODULES should load repo modules"
  expect_contains "$out" "nvm_loaded" "configured BASH_MODULES should load repo modules"
}

function assert_bash_profile_unset_dotfiles_dir_quiet {
  local tmp_home
  local out

  echo "OK: .bash_profile stays quiet when DOTFILES_DIR is unset in non-interactive shells"
  tmp_home="$(make_temp_home)"
  cp "$SCRIPT_DIR/src/bash/profiles/default/.bash_profile" "$tmp_home/.bash_profile"
  cat > "$tmp_home/.bashrc" <<'EOF'
#!/bin/bash
unset DOTFILES_DIR
EOF
  out="$(TERM='' run_bash_profile "$tmp_home" --noprofile --norc --rcfile "$tmp_home/.bash_profile" -i -c exit)"
  rm -rf "$tmp_home"
  expect_not_contains "$out" "DOTFILES_DIR is not set" ".bash_profile should not warn in non-interactive shells when DOTFILES_DIR is unset"
}

function assert_bash_profile_idempotent {
  local tmp_home
  local out

  echo "OK: .bash_profile is idempotent when sourced twice"
  tmp_home="$(make_temp_home)"
  setup_temp_profile_home "$tmp_home" "bash"
  # shellcheck disable=SC2016
  out="$(run_bash_profile "$tmp_home" --noprofile --norc -i -c 'source "$HOME/.bash_profile"; source "$HOME/.bash_profile"; printf "loaded:%s\n" "$DOTFILES_BASH_PROFILE_LOADED"; exit')"
  rm -rf "$tmp_home"
  expect_line_count "$out" '^Shell: bash$' 1 ".bash_profile should only initialize once"
  expect_contains "$out" "loaded:1" ".bash_profile should only initialize once"
}

function assert_zsh_profile_noninteractive_clean {
  local tmp_home
  local out

  echo "OK: .zshrc degrades cleanly when optional tooling is unavailable"
  tmp_home="$(make_temp_home)"
  setup_temp_profile_home "$tmp_home" "zsh"
  # shellcheck disable=SC2016
  out="$(run_zsh_profile "$tmp_home" -f -c 'source "$HOME/.zshrc"')"
  rm -rf "$tmp_home"
  expect_not_contains "$out" "command not found" ".zshrc should not require missing helper functions"
  expect_not_contains "$out" "Shell: zsh" ".zshrc should stay quiet in non-interactive shells"
}

function assert_zprofile_requires_zshrc {
  local tmp_home
  local out

  echo "OK: .zprofile fails clearly when .zshrc is missing"
  tmp_home="$(make_temp_home)"
  cp "$SCRIPT_DIR/src/bash/profiles/default/.zprofile" "$tmp_home/.zprofile"
  # shellcheck disable=SC2016
  out="$(run_zsh_profile "$tmp_home" -f -c 'source "$HOME/.zprofile"')"
  rm -rf "$tmp_home"
  expect_contains "$out" "Error: missing required file: $tmp_home/.zshrc" ".zprofile should require .zshrc"
}

function assert_zprofile_loads_zshrc {
  local tmp_home
  local out

  echo "OK: .zprofile proxies to .zshrc"
  tmp_home="$(make_temp_home)"
  setup_temp_profile_home "$tmp_home" "zsh"
  # shellcheck disable=SC2016
  out="$(run_zsh_profile "$tmp_home" -f -c 'source "$HOME/.zprofile"; alias gs >/dev/null 2>&1; echo gs:$?; print -r -- "zprofile_loaded:$DOTFILES_ZPROFILE_LOADED"; print -r -- "zshrc_loaded:$DOTFILES_ZSHRC_LOADED"')"
  rm -rf "$tmp_home"
  expect_contains "$out" "gs:0" ".zprofile should load .zshrc"
  expect_contains "$out" "zprofile_loaded:1" ".zprofile should mark itself as loaded"
  expect_contains "$out" "zshrc_loaded:1" ".zprofile should load .zshrc"
}

function assert_zsh_profile_loads_modules {
  local tmp_home
  local out

  echo "OK: .zshrc loads shared shell modules"
  tmp_home="$(make_temp_home)"
  setup_temp_profile_home "$tmp_home" "zsh"
  # shellcheck disable=SC2016
  out="$(run_zsh_profile "$tmp_home" -f -c 'source "$HOME/.zshrc"; alias gs >/dev/null 2>&1; echo gs:$?; alias gr >/dev/null 2>&1; echo gr:$?; whence prompt.dev >/dev/null 2>&1; echo prompt_dev:$?; whence git.parse_git_branch >/dev/null 2>&1; echo git_parse:$?')"
  rm -rf "$tmp_home"
  expect_contains "$out" "gs:0" ".zshrc should load shared shell modules"
  expect_contains "$out" "gr:0" ".zshrc should load shared shell modules"
  expect_contains "$out" "prompt_dev:0" ".zshrc should load shared shell modules"
  expect_contains "$out" "git_parse:0" ".zshrc should load shared shell modules"
}

function assert_zsh_profile_applies_prompt {
  local tmp_home
  local out

  echo "OK: interactive .zshrc applies prompt.dev"
  tmp_home="$(make_temp_home)"
  setup_temp_profile_home "$tmp_home" "zsh"
  # shellcheck disable=SC2016
  out="$(run_zsh_profile "$tmp_home" -i -c 'print -r -- "$PS1"')"
  rm -rf "$tmp_home"
  # shellcheck disable=SC2016
  expect_contains "$out" '$(prompt.git_branch) $ ' "interactive .zshrc should apply prompt.dev"
}

function assert_zsh_profile_invalid_dotfiles_dir_warns {
  local tmp_home
  local out

  echo "OK: interactive .zshrc warns when DOTFILES_DIR is invalid"
  tmp_home="$(make_temp_home)"
  cp "$SCRIPT_DIR/src/bash/profiles/default/.zshrc" "$tmp_home/.zshrc"
  cat > "$tmp_home/.bashrc" <<'EOF'
#!/bin/bash
export DOTFILES_DIR="/no/such/dotfiles"
export BASH_MODULES="$DOTFILES_DIR/src/bash/modules"
EOF
  out="$(run_zsh_profile "$tmp_home" -i -c exit)"
  rm -rf "$tmp_home"
  expect_contains "$out" "Error: DOTFILES_DIR does not exist: /no/such/dotfiles" "interactive .zshrc should warn on invalid DOTFILES_DIR"
}

function assert_zsh_profile_idempotent {
  local tmp_home
  local out

  echo "OK: .zshrc is idempotent when sourced twice"
  tmp_home="$(make_temp_home)"
  setup_temp_profile_home "$tmp_home" "zsh"
  # shellcheck disable=SC2016
  out="$(run_zsh_profile "$tmp_home" -i -c 'source "$HOME/.zshrc"; source "$HOME/.zshrc"; print -r -- "loaded:$DOTFILES_ZSHRC_LOADED"')"
  rm -rf "$tmp_home"
  expect_line_count "$out" '^Shell: zsh$' 1 ".zshrc should only initialize once"
  expect_contains "$out" "loaded:1" ".zshrc should only initialize once"
}

shopt -s nullglob
for script_path in "$MODULES_DIR"/*/*.sh; do
  # shellcheck disable=SC1090
  source "$script_path"
done
shopt -u nullglob

function require_func {
  local fn="$1"
  if ! declare -f "$fn" >/dev/null 2>&1; then
    fail "missing function: $fn"
  else
    echo "OK: $fn"
  fi
}

require_func "util.trim"
require_func "git.parse_git_branch"
require_func "prompt.git_branch"
require_func "prompt.dev"
require_func "display.is-highres"
require_func "node.nvm.setup"
require_func "node.nodenv.setup"
require_func "node.extract_node_modules"
require_func "node.restore_node_modules"
require_func "node.list_node_modules"
require_func "node.list_dep_mismatch"
require_func "node.nodenv.install"
require_func "node.nvm.install"
require_func "flib.photos"
require_func "flib.group"
require_func "gcu"
require_func "git.push"
require_func "git.set_author"
require_func "macos.set_screencapture_location"
require_func "vscode.install-extensions"
require_func "vscode.sort_settings"
require_func "vscode.setup-shell-command"

echo "OK: util.trim output"
expect_eq "$(util.trim "  hi  ")" "hi" "util.trim produced unexpected output"

echo "OK: prompt.git_branch can run"
if ! out="$(prompt.git_branch 2>/dev/null)"; then
  fail "prompt.git_branch errored"
else
  # We only sanity-check that it returns something like " (branch)" or empty.
  if [ -n "$out" ] && [[ "$out" != " ("*")" ]]; then
    fail "prompt.git_branch output format unexpected: $out"
  fi
fi

echo "OK: git.parse_git_branch returns the current branch in a repo"
tmp_git_dir="$(mktemp -d /tmp/my-dotfiles-git.XXXXXX)"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    cd "$2" || exit 1
    git init -q
    git checkout -q -b smoke-test-branch
    git.parse_git_branch
  ' _ "$MODULES_DIR/git/parse-git-branch.sh" "$tmp_git_dir" 2>/dev/null
)"
rm -rf "$tmp_git_dir"
expect_eq "$out" "(smoke-test-branch)" "git.parse_git_branch returned unexpected output"

echo "OK: flib.photos returns failure without exiting caller"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    PHOTOS_PARTIAL_PATH=/no/such/path/
    CODE_DIR="$2"
    flib.photos missing >/dev/null 2>&1
    printf "status:%s\n" "$?"
    echo after
  ' _ "$MODULES_DIR/flib/photos.sh" "$SCRIPT_DIR" 2>/dev/null
)"
expect_eq "$out" $'status:1\nafter' "flib.photos should return 1 without exiting caller"

echo "OK: flib.group fails cleanly without a subject"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    flib.group "" >/dev/null 2>&1
    printf "status:%s" "$?"
  ' _ "$MODULES_DIR/flib/group.sh"
)"
expect_eq "$out" "status:1" "flib.group should reject an empty subject"

echo "OK: node.extract_node_modules is quiet when there is nothing to move"
empty_code_dir="$(mktemp -d /tmp/my-dotfiles-smoke-code.XXXXXX)"
empty_temp_dir="$(mktemp -d /tmp/my-dotfiles-smoke-temp.XXXXXX)"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    source "$2"
    output="$(node.extract_node_modules "$3" "$4" 2>&1)"
    if [ -n "$output" ]; then
      printf "%s\n" "$output"
    fi
    printf "status:%s" "$?"
  ' _ "$MODULES_DIR/node/00-common.sh" "$MODULES_DIR/node/extract-node-modules.sh" "$empty_code_dir" "$empty_temp_dir"
)"
rm -rf "$empty_code_dir" "$empty_temp_dir"
expect_eq "$out" "status:0" "node.extract_node_modules should no-op cleanly"

echo "OK: node.list_node_modules is quiet when there is nothing to list"
empty_code_dir="$(mktemp -d /tmp/my-dotfiles-smoke-code.XXXXXX)"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    source "$2"
    output="$(node.list_node_modules "$3" 2>&1)"
    if [ -n "$output" ]; then
      printf "%s\n" "$output"
    fi
    printf "status:%s" "$?"
  ' _ "$MODULES_DIR/node/00-common.sh" "$MODULES_DIR/node/list-node-modules.sh" "$empty_code_dir"
)"
rm -rf "$empty_code_dir"
expect_eq "$out" "status:0" "node.list_node_modules should no-op cleanly"

echo "OK: git.push is wired through gcu"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    source "$2"
    declare -f git.push
  ' _ "$MODULES_DIR/git/gcu.sh" "$MODULES_DIR/git/push.sh"
)"
expect_contains "$out" 'gcu "$@" && git push' "git.push is not calling gcu"

echo "OK: vscode.install-extensions no-ops when no extensions are configured"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    unset MY_VSCODE_EXTENSIONS
    output="$(vscode.install-extensions 2>&1)"
    if [ -n "$output" ]; then
      printf "%s\n" "$output"
    fi
    printf "status:%s" "$?"
  ' _ "$MODULES_DIR/vscode/install-extensions.sh"
)"
expect_eq "$out" "status:0" "vscode.install-extensions should no-op cleanly"

echo "OK: install-shell-profile supports --profile all in plan mode"
out="$(
  bash --noprofile --norc "$SCRIPT_DIR/install-shell-profile" --list --profile all 2>&1
)"
expect_not_contains "$out" "Error: profile directory not found" "install-shell-profile should expand --profile all"

echo "OK: pull-shell-profile supports --profile all in plan mode"
out="$(
  bash --noprofile --norc "$SCRIPT_DIR/pull-shell-profile" --list --profile all 2>&1
)"
expect_not_contains "$out" "Error: profile directory not found" "pull-shell-profile should expand --profile all"

assert_bash_profile_noninteractive_clean
assert_bash_profile_requires_bashrc
assert_bash_profile_loads_modules
assert_bash_profile_unset_dotfiles_dir_quiet
assert_bash_profile_idempotent

if command -v zsh >/dev/null 2>&1; then
  assert_zprofile_requires_zshrc
  assert_zprofile_loads_zshrc
  assert_zsh_profile_noninteractive_clean
  assert_zsh_profile_loads_modules
  assert_zsh_profile_applies_prompt
  assert_zsh_profile_invalid_dotfiles_dir_warns
  assert_zsh_profile_idempotent
else
  echo "SKIP: zsh is not installed"
fi

if [ "$failures" -gt 0 ]; then
  echo "Smoke test finished with $failures failure(s)." >&2
  exit 1
fi

echo "Smoke test: PASS"

#!/usr/bin/env bash
set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MODULES_DIR="$SCRIPT_DIR/src/bash/modules"

echo "Smoke test: loading bash modules (no $HOME writes)"

if [ ! -d "$MODULES_DIR" ]; then
  echo "FAIL: modules directory not found: $MODULES_DIR" >&2
  exit 1
fi

failures=0

shopt -s nullglob
for module_path in "$MODULES_DIR/"*; do
  for script_path in "$module_path/"*.sh; do
    # shellcheck disable=SC1090
    source "$script_path"
  done
done
shopt -u nullglob

require_func() {
  local fn="$1"
  if ! declare -f "$fn" >/dev/null 2>&1; then
    echo "FAIL: missing function: $fn" >&2
    failures=$((failures+1))
  else
    echo "OK: $fn"
  fi
}

require_func "util.trim"
require_func "git.parse_git_branch"
require_func "prompt.git_branch"
require_func "prompt.dev"
require_func "display.is-highres"
require_func "node.nvm.setup"
require_func "node.nodenv.setup"
require_func "node.extract_node_modules"
require_func "node.restore_node_modules"
require_func "node.list_node_modules"
require_func "node.list_dep_mismatch"
require_func "node.nodenv.install"
require_func "node.nvm.install"
require_func "flib.photos"
require_func "flib.group"
require_func "gcu"
require_func "git.push"
require_func "vscode.install-extensions"
require_func "vscode.setup-shell-command"

echo "OK: util.trim output"
if [ "$(util.trim "  hi  ")" != "hi" ]; then
  echo "FAIL: util.trim produced unexpected output" >&2
  failures=$((failures+1))
fi

echo "OK: prompt.git_branch can run"
if ! out="$(prompt.git_branch 2>/dev/null)"; then
  echo "FAIL: prompt.git_branch errored" >&2
  failures=$((failures+1))
else
  # We only sanity-check that it returns something like " (branch)" or empty.
  if [ -n "$out" ] && [[ "$out" != " ("*")" ]]; then
    echo "FAIL: prompt.git_branch output format unexpected: $out" >&2
    failures=$((failures+1))
  fi
fi

echo "OK: git.parse_git_branch returns the current branch in a repo"
tmp_git_dir="$(mktemp -d /tmp/my-dotfiles-git.XXXXXX)"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    cd "$2" || exit 1
    git init -q
    git checkout -q -b smoke-test-branch
    git.parse_git_branch
  ' _ "$MODULES_DIR/git/parse-git-branch.sh" "$tmp_git_dir" 2>/dev/null
)"
rm -rf "$tmp_git_dir"
if [ "$out" != "(smoke-test-branch)" ]; then
  echo "FAIL: git.parse_git_branch returned unexpected output: $out" >&2
  failures=$((failures+1))
fi

echo "OK: flib.photos returns failure without exiting caller"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    PHOTOS_PARTIAL_PATH=/no/such/path/
    CODE_DIR="$2"
    flib.photos missing >/dev/null 2>&1
    printf "status:%s\n" "$?"
    echo after
  ' _ "$MODULES_DIR/flib/photos.sh" "$SCRIPT_DIR" 2>/dev/null
)"
if [ "$out" != $'status:1\nafter' ]; then
  echo "FAIL: flib.photos should return 1 without exiting caller: $out" >&2
  failures=$((failures+1))
fi

echo "OK: flib.group fails cleanly without a subject"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    flib.group "" >/dev/null 2>&1
    printf "status:%s" "$?"
  ' _ "$MODULES_DIR/flib/group.sh"
)"
if [ "$out" != "status:1" ]; then
  echo "FAIL: flib.group should reject an empty subject: $out" >&2
  failures=$((failures+1))
fi

echo "OK: node.extract_node_modules is quiet when there is nothing to move"
empty_code_dir="$(mktemp -d /tmp/my-dotfiles-smoke-code.XXXXXX)"
empty_temp_dir="$(mktemp -d /tmp/my-dotfiles-smoke-temp.XXXXXX)"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    output="$(node.extract_node_modules "$2" "$3" 2>&1)"
    if [ -n "$output" ]; then
      printf "%s\n" "$output"
    fi
    printf "status:%s" "$?"
  ' _ "$MODULES_DIR/node/extract-node-modules.sh" "$empty_code_dir" "$empty_temp_dir"
)"
rm -rf "$empty_code_dir" "$empty_temp_dir"
if [ "$out" != "status:0" ]; then
  echo "FAIL: node.extract_node_modules should no-op cleanly: $out" >&2
  failures=$((failures+1))
fi

echo "OK: node.list_node_modules is quiet when there is nothing to list"
empty_code_dir="$(mktemp -d /tmp/my-dotfiles-smoke-code.XXXXXX)"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    output="$(node.list_node_modules "$2" 2>&1)"
    if [ -n "$output" ]; then
      printf "%s\n" "$output"
    fi
    printf "status:%s" "$?"
  ' _ "$MODULES_DIR/node/list-node-modules.sh" "$empty_code_dir"
)"
rm -rf "$empty_code_dir"
if [ "$out" != "status:0" ]; then
  echo "FAIL: node.list_node_modules should no-op cleanly: $out" >&2
  failures=$((failures+1))
fi

echo "OK: git.push is wired through gcu"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    source "$2"
    declare -f git.push
  ' _ "$MODULES_DIR/git/gcu.sh" "$MODULES_DIR/git/push.sh"
)"
if [[ "$out" != *'gcu "$@" && git push'* ]]; then
  echo "FAIL: git.push is not calling gcu: $out" >&2
  failures=$((failures+1))
fi

echo "OK: vscode.install-extensions no-ops when no extensions are configured"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    unset MY_VSCODE_EXTENSIONS
    output="$(vscode.install-extensions 2>&1)"
    if [ -n "$output" ]; then
      printf "%s\n" "$output"
    fi
    printf "status:%s" "$?"
  ' _ "$MODULES_DIR/vscode/install-extensions.sh"
)"
if [ "$out" != "status:0" ]; then
  echo "FAIL: vscode.install-extensions should no-op cleanly: $out" >&2
  failures=$((failures+1))
fi

echo "OK: install-shell-profile supports --profile all in plan mode"
out="$(
  bash --noprofile --norc "$SCRIPT_DIR/install-shell-profile" --list --profile all 2>&1
)"
if [[ "$out" == *"Error: profile directory not found"* ]]; then
  echo "FAIL: install-shell-profile should expand --profile all: $out" >&2
  failures=$((failures+1))
fi

echo "OK: pull-shell-profile supports --profile all in plan mode"
out="$(
  bash --noprofile --norc "$SCRIPT_DIR/pull-shell-profile" --list --profile all 2>&1
)"
if [[ "$out" == *"Error: profile directory not found"* ]]; then
  echo "FAIL: pull-shell-profile should expand --profile all: $out" >&2
  failures=$((failures+1))
fi

echo "OK: .bash_profile degrades cleanly when modules are unavailable"
tmp_home="$(mktemp -d /tmp/my-dotfiles-home.XXXXXX)"
cp "$SCRIPT_DIR/src/bash/profiles/default/.bash_profile" "$tmp_home/.bash_profile"
cp "$SCRIPT_DIR/src/bash/profiles/default/.bashrc" "$tmp_home/.bashrc"
out="$(
  TERM='' HOME="$tmp_home" \
    bash --noprofile --norc --rcfile "$tmp_home/.bash_profile" -i -c exit 2>&1
)"
rm -rf "$tmp_home"
if [[ "$out" == *"command not found"* ]]; then
  echo "FAIL: .bash_profile should not call missing helper functions: $out" >&2
  failures=$((failures+1))
fi
if [[ "$out" == *"Shell: bash"* ]]; then
  echo "FAIL: .bash_profile should stay quiet in non-interactive shells: $out" >&2
  failures=$((failures+1))
fi

echo "OK: configured BASH_MODULES loads repo modules"
tmp_home="$(mktemp -d /tmp/my-dotfiles-home.XXXXXX)"
ln -s "$SCRIPT_DIR/src/bash/profiles/default/.bash_profile" "$tmp_home/.bash_profile"
cp "$SCRIPT_DIR/src/bash/profiles/default/.bashrc" "$tmp_home/.bashrc"
out="$(
  HOME="$tmp_home" \
    bash --rcfile "$tmp_home/.bash_profile" -i -c 'declare -f prompt.dev >/dev/null && echo prompt_loaded; declare -f node.nvm.setup >/dev/null && echo nvm_loaded; exit' 2>&1
)"
rm -rf "$tmp_home"
if [[ "$out" != *"prompt_loaded"* ]] || [[ "$out" != *"nvm_loaded"* ]]; then
  echo "FAIL: configured BASH_MODULES should load repo modules: $out" >&2
  failures=$((failures+1))
fi

echo "OK: .bash_profile stays quiet when DOTFILES_DIR is unset in non-interactive shells"
tmp_home="$(mktemp -d /tmp/my-dotfiles-home.XXXXXX)"
cp "$SCRIPT_DIR/src/bash/profiles/default/.bash_profile" "$tmp_home/.bash_profile"
cat > "$tmp_home/.bashrc" <<'EOF'
#!/bin/bash
unset DOTFILES_DIR
EOF
out="$(
  TERM='' HOME="$tmp_home" \
    bash --noprofile --norc --rcfile "$tmp_home/.bash_profile" -i -c exit 2>&1
)"
rm -rf "$tmp_home"
if [[ "$out" == *"DOTFILES_DIR is not set"* ]]; then
  echo "FAIL: .bash_profile should not warn in non-interactive shells when DOTFILES_DIR is unset: $out" >&2
  failures=$((failures+1))
fi

echo "OK: .zshrc degrades cleanly when optional tooling is unavailable"
if command -v zsh >/dev/null 2>&1; then
  tmp_home="$(mktemp -d /tmp/my-dotfiles-home.XXXXXX)"
  cp "$SCRIPT_DIR/src/bash/profiles/default/.zshrc" "$tmp_home/.zshrc"
  cp "$SCRIPT_DIR/src/bash/profiles/default/.bashrc" "$tmp_home/.bashrc"
  out="$(
    HOME="$tmp_home" zsh -f -c 'source "$HOME/.zshrc"' 2>&1
  )"
  rm -rf "$tmp_home"
  if [[ "$out" == *"command not found"* ]]; then
    echo "FAIL: .zshrc should not require missing helper functions: $out" >&2
    failures=$((failures+1))
  fi
  if [[ "$out" == *"Shell: zsh"* ]]; then
    echo "FAIL: .zshrc should stay quiet in non-interactive shells: $out" >&2
    failures=$((failures+1))
  fi

  echo "OK: .zshrc loads shared git aliases"
  tmp_home="$(mktemp -d /tmp/my-dotfiles-home.XXXXXX)"
  cp "$SCRIPT_DIR/src/bash/profiles/default/.zshrc" "$tmp_home/.zshrc"
  cp "$SCRIPT_DIR/src/bash/profiles/default/.bashrc" "$tmp_home/.bashrc"
  out="$(
    HOME="$tmp_home" zsh -f -c 'source "$HOME/.zshrc"; alias gs >/dev/null 2>&1; echo gs:$?; alias gr >/dev/null 2>&1; echo gr:$?' 2>&1
  )"
  rm -rf "$tmp_home"
  if [[ "$out" != *"gs:0"* ]] || [[ "$out" != *"gr:0"* ]]; then
    echo "FAIL: .zshrc should load shared git aliases: $out" >&2
    failures=$((failures+1))
  fi
else
  echo "SKIP: zsh is not installed"
fi

if [ "$failures" -gt 0 ]; then
  echo "Smoke test finished with $failures failure(s)." >&2
  exit 1
fi

echo "Smoke test: PASS"

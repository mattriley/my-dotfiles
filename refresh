#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR" || exit 1

source "$SCRIPT_DIR/src/bash/script-common.sh"

dotfiles.parse_profile_args "Usage: $0 [--dry-run] [--profile <name|all>]" 0 "$@" || exit 1

function sort_vscode_settings {
    if [ "$DRY_RUN" -eq 0 ]; then
        command -v node >/dev/null 2>&1 || return 0
    fi

    local profiles_dir="$SCRIPT_DIR/src/bash/profiles"
    [ -d "$profiles_dir" ] || return 0

    dotfiles.collect_profiles "$profiles_dir" "$PROFILE" || return 1

    local profile_dir
    for profile_dir in "${DOTFILES_PROFILES[@]}"; do
        local profile_path="$profiles_dir/$profile_dir"
        [ -d "$profile_path" ] || continue

        # Escape the space in "Application Support" so pathname expansion works.
        # Enable nullglob so an empty glob doesn't become a literal "*".
        shopt -s nullglob
        local settings_path
        for settings_path in "$profile_path"/Library/Application\ Support/Code/*/settings.json; do
            if [ "$DRY_RUN" -eq 1 ]; then
                echo "DRY RUN: sort VSCode settings: $settings_path"
            else
                node "$SCRIPT_DIR/src/node/sort-vscode-settings.js" "$settings_path"
            fi
        done
        shopt -u nullglob
    done
}

function set_git_author {
    [ "$DRY_RUN" -eq 1 ] && return 0
    command -v git >/dev/null 2>&1 || return 0

    [ -n "$MY_AUTHOR_NAME" ] || return 0
    [ -n "$MY_AUTHOR_EMAIL" ] || return 0

    git config --global user.name "$MY_AUTHOR_NAME" || return 1
    git config --global user.email "$MY_AUTHOR_EMAIL" || return 1
}

function set_screencapture_location {
    [ "$DRY_RUN" -eq 1 ] && return 0
    command -v defaults >/dev/null 2>&1 || return 0
    command -v killall >/dev/null 2>&1 || return 0

    if [ -n "$SCREENCAPTURE_DIR" ] && [ -d "$SCREENCAPTURE_DIR" ]; then
        if defaults write com.apple.screencapture location "$SCREENCAPTURE_DIR"; then
            killall SystemUIServer 2>/dev/null || true
            echo "Screenshot location set to $SCREENCAPTURE_DIR"
        else
            echo "Error: failed to set screenshot location via defaults" >&2
            return 1
        fi
    else
        echo "Error: Directory $SCREENCAPTURE_DIR does not exist"
        return 1
    fi
}

overall_status=0
if [ "$DRY_RUN" -eq 1 ]; then
    "$SCRIPT_DIR/install-shell-profile" --dry-run --profile "$PROFILE" || overall_status=1
else
    "$SCRIPT_DIR/install-shell-profile" --profile "$PROFILE" || overall_status=1
fi

# Provide sane defaults when `refresh` is run outside a shell startup.
: "${HOME_DIR:=$HOME/Home}"
: "${SCREENCAPTURE_DIR:=$HOME_DIR/Screenshots}"
: "${MY_AUTHOR_NAME:=Matt Riley}"
: "${MY_AUTHOR_EMAIL:=m@ttriley.dev}"

sort_vscode_settings || overall_status=1
set_git_author || overall_status=1
set_screencapture_location || overall_status=1

if [ "$overall_status" -ne 0 ]; then
    echo "refresh: finished with errors (profile=$PROFILE, dry-run=$DRY_RUN)." >&2
    exit "$overall_status"
fi

echo "refresh: OK (profile=$PROFILE, dry-run=$DRY_RUN)"

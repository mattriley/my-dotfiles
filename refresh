#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR" || exit 1

# shellcheck disable=SC1091
source "$SCRIPT_DIR/src/bash/script_common.sh"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/src/bash/profile_common.sh"

export DOTFILES_DIR="$SCRIPT_DIR"
dotfiles.validate_dotfiles_dir 0 || true
dotfiles.load_modules

dotfiles.parse_profile_args "Usage: $0 [--dry-run] [--profile <name|all>]" 0 "$@"
parse_status=$?
[ "$parse_status" -eq 2 ] && exit 0
[ "$parse_status" -eq 0 ] || exit 1

overall_status=0
if [ "$DRY_RUN" -eq 1 ]; then
    "$SCRIPT_DIR/install_shell_profile" --dry-run --profile "$PROFILE" || overall_status=1
else
    "$SCRIPT_DIR/install_shell_profile" --profile "$PROFILE" || overall_status=1
fi

# shellcheck disable=SC1090,SC1091
[ -f "$DOTFILES_DIR/profiles/$PROFILE/env.sh" ] && source "$DOTFILES_DIR/profiles/$PROFILE/env.sh"

if [ "$DRY_RUN" -eq 0 ]; then
    brew.bundle_dump "$SCRIPT_DIR" "$PROFILE" || overall_status=1
    vscode.sort_settings "$SCRIPT_DIR" "$PROFILE" || overall_status=1
fi
[ "$DRY_RUN" -eq 1 ] || git.set_author.default || overall_status=1
[ "$DRY_RUN" -eq 1 ] || iterm2.set_default_bookmark.default || overall_status=1
[ "$DRY_RUN" -eq 1 ] || macos.set_screencapture_location.default || overall_status=1

if [ "$overall_status" -ne 0 ]; then
    echo "refresh: finished with errors (profile=$PROFILE, dry-run=$DRY_RUN)." >&2
    exit "$overall_status"
fi

echo "refresh: OK (profile=$PROFILE, dry-run=$DRY_RUN)"

#!/bin/bash

if [ -n "${TERM:-}" ] && command -v tput >/dev/null 2>&1; then
    NORM=$(tput sgr0)
    BOLD=$(tput bold)
else
    NORM=""
    BOLD=""
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

DRY_RUN=0
LIST_ONLY=0
PROFILE="default"

while [ $# -gt 0 ]; do
    case "$1" in
        --dry-run)
            DRY_RUN=1
            shift
            ;;
        --list|--plan)
            DRY_RUN=1
            LIST_ONLY=1
            shift
            ;;
        --profile=*)
            PROFILE="${1#*=}"
            shift
            ;;
        --profile)
            PROFILE="${2:-default}"
            shift 2
            ;;
        -h|--help)
            echo "Usage: $0 [--dry-run|--list|--plan] [--profile <name>]"
            exit 0
            ;;
        *)
            # Back-compat: first non-flag argument is the profile name.
            PROFILE="$1"
            shift
            ;;
    esac
done

function install_shell_profile {
    local profile="$1"    
    local target="$SCRIPT_DIR/src/bash/profiles/$profile"

    if [ ! -d "$target" ]; then
        echo "Error: profile directory not found: $target" >&2
        return 1
    fi

    echo "Installing $BOLD$profile$NORM profile..."
    echo

    local failures=0
    local processed=0
    while IFS= read -r -d '' path; do 
            local dest="$HOME${path#"$target"}"
            local base; base="$(basename "$path")"
            # Skip editor/system cruft so it doesn't get installed into $HOME
            [ "$base" = ".DS_Store" ] && continue

            processed=$((processed+1))

            if [ "$DRY_RUN" -eq 1 ]; then
                if [ "$LIST_ONLY" -eq 1 ]; then
                    echo "LIST: ln -sfv \"$path\" \"$dest\""
                else
                    echo "DRY RUN: ln -sfv \"$path\" \"$dest\""
                fi
                continue
            fi

            mkdir -p "$(dirname "$dest")" || { failures=$((failures+1)); continue; }
            ln -sfv "$path" "$dest" || failures=$((failures+1))
        done < <(find "$target" -type f -print0)

    if [ "$DRY_RUN" -eq 1 ]; then
        echo
        echo "Plan complete: would process $processed file(s)."
        return 0
    fi

    if [ "$failures" -gt 0 ]; then
        echo "Completed with $failures error(s)." >&2
        return 1
    fi

    echo
}

function install_profiles {
    local profiles_dir="$SCRIPT_DIR/src/bash/profiles"
    local profiles=()
    local status=0
    local profile_dir

    if [ "$PROFILE" = "all" ] || [ -z "$PROFILE" ]; then
        shopt -s nullglob
        for profile_dir in "$profiles_dir"/*; do
            [ -d "$profile_dir" ] || continue
            profiles+=("$(basename "$profile_dir")")
        done
        shopt -u nullglob
    else
        profiles=("$PROFILE")
    fi

    [ "${#profiles[@]}" -gt 0 ] || {
        echo "Error: no profiles found in $profiles_dir" >&2
        return 1
    }

    for profile_dir in "${profiles[@]}"; do
        install_shell_profile "$profile_dir" || status=1
    done

    return "$status"
}

echo
install_profiles

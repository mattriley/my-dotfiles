#!/bin/bash

NORM=$(tput sgr0)
BOLD=$(tput bold)

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

DRY_RUN=0
PROFILE="default"

while [ $# -gt 0 ]; do
    case "$1" in
        --dry-run)
            DRY_RUN=1
            shift
            ;;
        --profile=*)
            PROFILE="${1#*=}"
            shift
            ;;
        --profile)
            PROFILE="${2:-default}"
            shift 2
            ;;
        -h|--help)
            echo "Usage: $0 [--dry-run] [--profile <name>]"
            exit 0
            ;;
        *)
            # Back-compat: first non-flag argument is the profile name.
            PROFILE="$1"
            shift
            ;;
    esac
done

function pull_shell_profile {
    local profile="$1"    
    local target="$SCRIPT_DIR/src/bash/profiles/$profile"

    if [ ! -d "$target" ]; then
        echo "Error: profile directory not found: $target" >&2
        return 1
    fi

    echo "Pulling $BOLD$profile$NORM profile..."
    echo

    local failures=0
    find "$target" -type f -print0 | 
        while IFS= read -r -d '' path; do 
            local dest="$HOME${path#"$target"}"
            local base; base="$(basename "$path")"
            # Skip editor/system cruft so it doesn't get pulled into the repo
            [ "$base" = ".DS_Store" ] && continue
            # Only pull regular files (avoid overwriting repo-managed symlinks).
            [ ! -L "$dest" ] || continue
            [ -e "$dest" ] || continue

            if [ "$DRY_RUN" -eq 1 ]; then
                echo "DRY RUN: cp -f \"$dest\" \"$path\""
                continue
            fi

            cp -f "$dest" "$path" || failures=$((failures+1))
        done

    if [ "$failures" -gt 0 ]; then
        echo "Completed with $failures error(s)." >&2
        return 1
    fi

    echo
}

echo
pull_shell_profile "$PROFILE"

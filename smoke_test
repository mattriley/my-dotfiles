#!/usr/bin/env bash
set -u

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MODULES_DIR="$SCRIPT_DIR/src/bash/modules"

echo "Smoke test: loading bash modules (no $HOME writes)"

if [ ! -d "$MODULES_DIR" ]; then
  echo "FAIL: modules directory not found: $MODULES_DIR" >&2
  exit 1
fi

failures=0
RUN_OUTPUT=''
RUN_STATUS=0

function fail {
  local message="$1"
  echo "FAIL: $message" >&2
  failures=$((failures+1))
}

function expect_eq {
  local actual="$1"
  local expected="$2"
  local message="$3"
  [ "$actual" = "$expected" ] || fail "$message: $actual"
}

function expect_contains {
  local haystack="$1"
  local needle="$2"
  local message="$3"
  [[ "$haystack" == *"$needle"* ]] || fail "$message: $haystack"
}

function expect_not_contains {
  local haystack="$1"
  local needle="$2"
  local message="$3"
  [[ "$haystack" != *"$needle"* ]] || fail "$message: $haystack"
}

function expect_line_count {
  local haystack="$1"
  local pattern="$2"
  local expected_count="$3"
  local message="$4"
  local actual_count
  actual_count="$(printf '%s\n' "$haystack" | grep -c "$pattern")"
  [ "$actual_count" -eq "$expected_count" ] || fail "$message: $haystack"
}

function normalize_bash_interactive_output {
  local output="$1"
  printf '%s\n' "$output" |
    sed '/^bash: cannot set terminal process group /d' |
    sed '/^bash: no job control in this shell$/d' |
    sed '/^exit$/d'
}

function make_temp_home {
  mktemp -d /tmp/my-dotfiles-home.XXXXXX
}

function setup_temp_profile_home {
  local tmp_home="$1"
  local shell_name="$2"

  cp "$SCRIPT_DIR/profiles/default/link/.bashrc" "$tmp_home/.bashrc"
  if [ "$shell_name" = "bash" ]; then
    cp "$SCRIPT_DIR/profiles/default/link/.bash_profile" "$tmp_home/.bash_profile"
  else
    cp "$SCRIPT_DIR/profiles/default/link/.zprofile" "$tmp_home/.zprofile"
    cp "$SCRIPT_DIR/profiles/default/link/.zshrc" "$tmp_home/.zshrc"
  fi
}

function run_bash_profile {
  local tmp_home="$1"
  shift
  /usr/bin/env -u BASH_ENV -u ENV -u DOTFILES_BASH_PROFILE_LOADED HOME="$tmp_home" /bin/bash "$@" 2>&1
}

function run_zsh_profile {
  local tmp_home="$1"
  shift
  /usr/bin/env -u DOTFILES_ZPROFILE_LOADED -u DOTFILES_ZSHRC_LOADED HOME="$tmp_home" /bin/zsh "$@" 2>&1
}

function run_bash_script_in_home {
  local tmp_home="$1"
  local script_body="$2"
  local tmp_script
  local tmp_output

  tmp_script="$(mktemp /tmp/my-dotfiles-bash-script.XXXXXX)" || return 1
  tmp_output="$(mktemp /tmp/my-dotfiles-bash-output.XXXXXX)" || {
    rm -f "$tmp_script"
    return 1
  }
  {
    printf 'export HOME=%q\n' "$tmp_home"
    printf '%s\n' "$script_body"
  } > "$tmp_script"
  chmod +x "$tmp_script"
  if run_bash_profile "$tmp_home" --noprofile --norc "$tmp_script" >"$tmp_output"; then
    RUN_STATUS=0
  else
    RUN_STATUS=$?
  fi
  rm -f "$tmp_script"
  RUN_OUTPUT="$(cat "$tmp_output")"
  rm -f "$tmp_output"
  return "$RUN_STATUS"
}

function assert_bash_profile_noninteractive_clean {
  local tmp_home
  echo "OK: .bash_profile degrades cleanly when modules are unavailable"
  tmp_home="$(make_temp_home)"
  setup_temp_profile_home "$tmp_home" "bash"
  # shellcheck disable=SC2016
  TERM='' run_bash_script_in_home "$tmp_home" 'source "$HOME/.bash_profile"'
  rm -rf "$tmp_home"
  expect_not_contains "$RUN_OUTPUT" "command not found" ".bash_profile should not call missing helper functions"
  expect_not_contains "$RUN_OUTPUT" "Shell: bash" ".bash_profile should stay quiet in non-interactive shells"
}

function assert_bash_profile_requires_bashrc {
  local tmp_home

  echo "OK: .bash_profile fails clearly when .bashrc is missing"
  tmp_home="$(make_temp_home)"
  cp "$SCRIPT_DIR/profiles/default/link/.bash_profile" "$tmp_home/.bash_profile"
  # shellcheck disable=SC2016
  run_bash_script_in_home "$tmp_home" 'source "$HOME/.bash_profile"'
  rm -rf "$tmp_home"
  if [ -n "${SMOKE_TEST_DEBUG:-}" ]; then
    printf 'DEBUG: assert_bash_profile_requires_bashrc status=<%s> out=<%s>\n' "$RUN_STATUS" "$RUN_OUTPUT" >&2
  fi
  expect_contains "$RUN_OUTPUT" "Error: missing required file: $tmp_home/.bashrc" ".bash_profile should require .bashrc"
}

function assert_bash_profile_loads_modules {
  local tmp_home

  echo "OK: configured BASH_MODULES loads repo modules"
  tmp_home="$(make_temp_home)"
  ln -s "$SCRIPT_DIR/profiles/default/link/.bash_profile" "$tmp_home/.bash_profile"
  cp "$SCRIPT_DIR/profiles/default/link/.bashrc" "$tmp_home/.bashrc"
  # shellcheck disable=SC2016
  run_bash_script_in_home "$tmp_home" 'source "$HOME/.bash_profile"; declare -f prompt.dev >/dev/null && echo prompt_loaded; declare -f node.nvm.setup >/dev/null && echo nvm_loaded'
  rm -rf "$tmp_home"
  if [ -n "${SMOKE_TEST_DEBUG:-}" ]; then
    printf 'DEBUG: assert_bash_profile_loads_modules status=<%s> out=<%s>\n' "$RUN_STATUS" "$RUN_OUTPUT" >&2
  fi
  expect_contains "$RUN_OUTPUT" "prompt_loaded" "configured BASH_MODULES should load repo modules"
  expect_contains "$RUN_OUTPUT" "nvm_loaded" "configured BASH_MODULES should load repo modules"
}

function assert_bash_profile_unset_dotfiles_dir_quiet {
  local tmp_home

  echo "OK: .bash_profile stays quiet when DOTFILES_DIR is unset in non-interactive shells"
  tmp_home="$(make_temp_home)"
  cp "$SCRIPT_DIR/profiles/default/link/.bash_profile" "$tmp_home/.bash_profile"
  cat > "$tmp_home/.bashrc" <<'EOF'
#!/bin/bash
unset DOTFILES_DIR
EOF
  # shellcheck disable=SC2016
  TERM='' run_bash_script_in_home "$tmp_home" 'source "$HOME/.bash_profile"'
  rm -rf "$tmp_home"
  expect_not_contains "$RUN_OUTPUT" "DOTFILES_DIR is not set" ".bash_profile should not warn in non-interactive shells when DOTFILES_DIR is unset"
}

function assert_bash_profile_idempotent {
  local tmp_home

  echo "OK: .bash_profile is idempotent when sourced twice"
  tmp_home="$(make_temp_home)"
  setup_temp_profile_home "$tmp_home" "bash"
  # shellcheck disable=SC2016
  run_bash_script_in_home "$tmp_home" 'source "$HOME/.bash_profile"; source "$HOME/.bash_profile"; printf "loaded:%s\n" "$DOTFILES_BASH_PROFILE_LOADED"; printf "brew_count:%s\n" "$(printf "%s" "$PATH" | awk -F: '"'"'{c=0; for (i=1; i<=NF; i++) if ($i=="/opt/homebrew/bin") c++; print c}'"'"')"'
  rm -rf "$tmp_home"
  expect_contains "$RUN_OUTPUT" "loaded:1" ".bash_profile should only initialize once"
  expect_contains "$RUN_OUTPUT" "brew_count:1" ".bash_profile should only initialize once"
}

function assert_zsh_profile_noninteractive_clean {
  local tmp_home
  local out

  echo "OK: .zshrc degrades cleanly when optional tooling is unavailable"
  tmp_home="$(make_temp_home)"
  setup_temp_profile_home "$tmp_home" "zsh"
  # shellcheck disable=SC2016
  out="$(run_zsh_profile "$tmp_home" -f -c 'source "$HOME/.zshrc"')"
  rm -rf "$tmp_home"
  expect_not_contains "$out" "command not found" ".zshrc should not require missing helper functions"
  expect_not_contains "$out" "Shell: zsh" ".zshrc should stay quiet in non-interactive shells"
}

function assert_zprofile_requires_zshrc {
  local tmp_home
  local out

  echo "OK: .zprofile fails clearly when .zshrc is missing"
  tmp_home="$(make_temp_home)"
  cp "$SCRIPT_DIR/profiles/default/link/.zprofile" "$tmp_home/.zprofile"
  # shellcheck disable=SC2016
  out="$(run_zsh_profile "$tmp_home" -f -c 'source "$HOME/.zprofile"')"
  rm -rf "$tmp_home"
  expect_contains "$out" "Error: missing required file: $tmp_home/.zshrc" ".zprofile should require .zshrc"
}

function assert_zprofile_loads_zshrc {
  local tmp_home
  local out

  echo "OK: .zprofile proxies to .zshrc"
  tmp_home="$(make_temp_home)"
  setup_temp_profile_home "$tmp_home" "zsh"
  # shellcheck disable=SC2016
  out="$(run_zsh_profile "$tmp_home" -f -c 'source "$HOME/.zprofile"; alias gs >/dev/null 2>&1; echo gs:$?; print -r -- "zprofile_loaded:$DOTFILES_ZPROFILE_LOADED"; print -r -- "zshrc_loaded:$DOTFILES_ZSHRC_LOADED"')"
  rm -rf "$tmp_home"
  expect_contains "$out" "gs:0" ".zprofile should load .zshrc"
  expect_contains "$out" "zprofile_loaded:1" ".zprofile should mark itself as loaded"
  expect_contains "$out" "zshrc_loaded:1" ".zprofile should load .zshrc"
}

function assert_zsh_profile_loads_modules {
  local tmp_home
  local out

  echo "OK: .zshrc loads shared shell modules"
  tmp_home="$(make_temp_home)"
  setup_temp_profile_home "$tmp_home" "zsh"
  # shellcheck disable=SC2016
  out="$(run_zsh_profile "$tmp_home" -f -c 'source "$HOME/.zshrc"; alias gs >/dev/null 2>&1; echo gs:$?; alias gr >/dev/null 2>&1; echo gr:$?; whence prompt.dev >/dev/null 2>&1; echo prompt_dev:$?; whence git.parse_git_branch >/dev/null 2>&1; echo git_parse:$?')"
  rm -rf "$tmp_home"
  expect_contains "$out" "gs:0" ".zshrc should load shared shell modules"
  expect_contains "$out" "gr:0" ".zshrc should load shared shell modules"
  expect_contains "$out" "prompt_dev:0" ".zshrc should load shared shell modules"
  expect_contains "$out" "git_parse:0" ".zshrc should load shared shell modules"
}

function assert_zsh_profile_applies_prompt {
  local tmp_home
  local out

  echo "OK: interactive .zshrc applies prompt.dev"
  tmp_home="$(make_temp_home)"
  setup_temp_profile_home "$tmp_home" "zsh"
  # shellcheck disable=SC2016
  out="$(run_zsh_profile "$tmp_home" -i -c 'print -r -- "$PS1"')"
  rm -rf "$tmp_home"
  # shellcheck disable=SC2016
  expect_contains "$out" '$(prompt.git_branch) $ ' "interactive .zshrc should apply prompt.dev"
}

function assert_zsh_profile_invalid_dotfiles_dir_warns {
  local tmp_home
  local out

  echo "OK: interactive .zshrc warns when DOTFILES_DIR is invalid"
  tmp_home="$(make_temp_home)"
  cp "$SCRIPT_DIR/profiles/default/link/.zshrc" "$tmp_home/.zshrc"
  cat > "$tmp_home/.bashrc" <<'EOF'
#!/bin/bash
export DOTFILES_DIR="/no/such/dotfiles"
export BASH_MODULES="$DOTFILES_DIR/src/bash/modules"
EOF
  out="$(run_zsh_profile "$tmp_home" -i -c exit)"
  rm -rf "$tmp_home"
  expect_contains "$out" "Error: DOTFILES_DIR does not exist: /no/such/dotfiles" "interactive .zshrc should warn on invalid DOTFILES_DIR"
}

function assert_zsh_profile_idempotent {
  local tmp_home
  local out

  echo "OK: .zshrc is idempotent when sourced twice"
  tmp_home="$(make_temp_home)"
  setup_temp_profile_home "$tmp_home" "zsh"
  # shellcheck disable=SC2016
  out="$(run_zsh_profile "$tmp_home" -i -c 'source "$HOME/.zshrc"; source "$HOME/.zshrc"; print -r -- "loaded:$DOTFILES_ZSHRC_LOADED"')"
  rm -rf "$tmp_home"
  expect_line_count "$out" '^Shell: zsh$' 1 ".zshrc should only initialize once"
  expect_contains "$out" "loaded:1" ".zshrc should only initialize once"
}

shopt -s nullglob
for script_path in "$MODULES_DIR"/*/*.sh; do
  # shellcheck disable=SC1090
  source "$script_path"
done
shopt -u nullglob

function require_func {
  local fn="$1"
  if ! declare -f "$fn" >/dev/null 2>&1; then
    fail "missing function: $fn"
  else
    echo "OK: $fn"
  fi
}

require_func "util.trim"
require_func "git.parse_git_branch"
require_func "prompt.git_branch"
require_func "prompt.dev"
require_func "display.is_highres"
require_func "node.nvm.setup"
require_func "node.nodenv.setup"
require_func "node.extract_node_modules"
require_func "node.restore_node_modules"
require_func "node.list_node_modules"
require_func "node.list_dep_mismatch"
require_func "node.nodenv.install"
require_func "node.nvm.install"
require_func "flib.photos"
require_func "flib.group"
require_func "brew.bundle_dump"
require_func "brew.bundle_install"
require_func "gcu"
require_func "git.push"
require_func "git.set_author"
require_func "git.set_author.default"
require_func "iterm2.set_default_bookmark"
require_func "iterm2.set_default_bookmark.default"
require_func "macos.set_screencapture_location"
require_func "macos.set_screencapture_location.default"
require_func "vscode.sort_settings"
require_func "vscode.setup_shell_command"

echo "OK: util.trim output"
expect_eq "$(util.trim "  hi  ")" "hi" "util.trim produced unexpected output"

echo "OK: prompt.git_branch can run"
if ! out="$(prompt.git_branch 2>/dev/null)"; then
  fail "prompt.git_branch errored"
else
  # We only sanity-check that it returns something like " (branch)" or empty.
  if [ -n "$out" ] && [[ "$out" != " ("*")" ]]; then
    fail "prompt.git_branch output format unexpected: $out"
  fi
fi

echo "OK: git.parse_git_branch returns the current branch in a repo"
tmp_git_dir="$(mktemp -d /tmp/my-dotfiles-git.XXXXXX)"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    cd "$2" || exit 1
    git init -q
    git checkout -q -b smoke_test_branch
    git.parse_git_branch
  ' _ "$MODULES_DIR/git/parse_git_branch.sh" "$tmp_git_dir" 2>/dev/null
)"
rm -rf "$tmp_git_dir"
expect_eq "$out" "(smoke_test_branch)" "git.parse_git_branch returned unexpected output"

echo "OK: flib.photos returns failure without exiting caller"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    PHOTOS_PARTIAL_PATH=/no/such/path/
    CODE_DIR="$2"
    flib.photos missing >/dev/null 2>&1
    printf "status:%s\n" "$?"
    echo after
  ' _ "$MODULES_DIR/flib/photos.sh" "$SCRIPT_DIR" 2>/dev/null
)"
expect_eq "$out" $'status:1\nafter' "flib.photos should return 1 without exiting caller"

echo "OK: flib.group fails cleanly without a subject"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    flib.group "" >/dev/null 2>&1
    printf "status:%s" "$?"
  ' _ "$MODULES_DIR/flib/group.sh"
)"
expect_eq "$out" "status:1" "flib.group should reject an empty subject"

echo "OK: node.extract_node_modules is quiet when there is nothing to move"
empty_code_dir="$(mktemp -d /tmp/my-dotfiles-smoke-code.XXXXXX)"
empty_temp_dir="$(mktemp -d /tmp/my-dotfiles-smoke-temp.XXXXXX)"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    source "$2"
    output="$(node.extract_node_modules "$3" "$4" 2>&1)"
    if [ -n "$output" ]; then
      printf "%s\n" "$output"
    fi
    printf "status:%s" "$?"
  ' _ "$MODULES_DIR/node/00_common.sh" "$MODULES_DIR/node/extract_node_modules.sh" "$empty_code_dir" "$empty_temp_dir"
)"
rm -rf "$empty_code_dir" "$empty_temp_dir"
expect_eq "$out" "status:0" "node.extract_node_modules should no-op cleanly"

echo "OK: node.list_node_modules is quiet when there is nothing to list"
empty_code_dir="$(mktemp -d /tmp/my-dotfiles-smoke-code.XXXXXX)"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    source "$2"
    output="$(node.list_node_modules "$3" 2>&1)"
    if [ -n "$output" ]; then
      printf "%s\n" "$output"
    fi
    printf "status:%s" "$?"
  ' _ "$MODULES_DIR/node/00_common.sh" "$MODULES_DIR/node/list_node_modules.sh" "$empty_code_dir"
)"
rm -rf "$empty_code_dir"
expect_eq "$out" "status:0" "node.list_node_modules should no-op cleanly"

echo "OK: git.push is wired through gcu"
out="$(
  bash --noprofile --norc -c '
    source "$1"
    source "$2"
    declare -f git.push
  ' _ "$MODULES_DIR/git/gcu.sh" "$MODULES_DIR/git/push.sh"
)"
expect_contains "$out" 'gcu "$@" && git push' "git.push is not calling gcu"

echo "OK: apply_profile supports --profile all in plan mode"
out="$(
  bash --noprofile --norc "$SCRIPT_DIR/apply_profile" --list --profile all 2>&1
)"
expect_not_contains "$out" "Error: profile link directory not found" "apply_profile should expand --profile all"
expect_not_contains "$out" "Error: profile copy directory not found" "apply_profile should expand --profile all"
expect_contains "$out" 'LIST COPY: cp -f "/Users/mattriley/Home/Code/my-dotfiles/profiles/default/copy/Library/Application Support/iTerm2/DynamicProfiles/Matt Riley.json" "/Users/mattriley/Library/Application Support/iTerm2/DynamicProfiles/Matt Riley.json"' "apply_profile should copy copy-managed files"

echo "OK: capture_profile supports --profile all in plan mode"
out="$(
  bash --noprofile --norc "$SCRIPT_DIR/capture_profile" --list --profile all 2>&1
)"
expect_not_contains "$out" "Error: profile link directory not found" "capture_profile should expand --profile all"
  expect_not_contains "$out" "Error: profile copy directory not found" "capture_profile should expand --profile all"
expect_contains "$out" 'LIST BREW: brew bundle dump --file "/Users/mattriley/Home/Code/my-dotfiles/profiles/default/Brewfile" --force' "capture_profile should include a Brewfile dump"

echo "OK: apply_profile copies copy-managed files"
tmp_home="$(make_temp_home)"
out="$(
  HOME="$tmp_home" bash --noprofile --norc "$SCRIPT_DIR/apply_profile" --profile default 2>&1
)"
[ -L "$tmp_home/.bashrc" ] || fail "apply_profile should symlink link-managed files"
[ -f "$tmp_home/Library/Application Support/iTerm2/DynamicProfiles/Matt Riley.json" ] || fail "apply_profile should create copy-managed files"
[ ! -L "$tmp_home/Library/Application Support/iTerm2/DynamicProfiles/Matt Riley.json" ] || fail "apply_profile should copy, not symlink, copy-managed files"
rm -rf "$tmp_home"

echo "OK: apply_profile replaces broken symlinks for link-managed files"
tmp_home="$(make_temp_home)"
ln -s "$SCRIPT_DIR/profiles/default/link/.bashrc" "$tmp_home/.bashrc"
out="$(
  HOME="$tmp_home" bash --noprofile --norc "$SCRIPT_DIR/apply_profile" --profile default 2>&1
)"
[ -L "$tmp_home/.bashrc" ] || fail "apply_profile should keep link-managed files as symlinks"
[ "$(readlink "$tmp_home/.bashrc")" = "$SCRIPT_DIR/profiles/default/link/.bashrc" ] || fail "apply_profile should replace broken link-managed symlinks"
rm -rf "$tmp_home"

echo "OK: apply_profile replaces broken symlinks for copy-managed files"
tmp_home="$(make_temp_home)"
mkdir -p "$tmp_home/Library/Application Support/iTerm2/DynamicProfiles"
ln -s "$SCRIPT_DIR/profiles/default/Library/Application Support/iTerm2/DynamicProfiles/Matt Riley.json" "$tmp_home/Library/Application Support/iTerm2/DynamicProfiles/Matt Riley.json"
out="$(
  HOME="$tmp_home" bash --noprofile --norc "$SCRIPT_DIR/apply_profile" --profile default 2>&1
)"
[ -f "$tmp_home/Library/Application Support/iTerm2/DynamicProfiles/Matt Riley.json" ] || fail "apply_profile should replace broken symlinks for copy-managed files"
[ ! -L "$tmp_home/Library/Application Support/iTerm2/DynamicProfiles/Matt Riley.json" ] || fail "apply_profile should replace broken symlinks with copied files"
rm -rf "$tmp_home"

assert_bash_profile_noninteractive_clean
assert_bash_profile_requires_bashrc
assert_bash_profile_loads_modules
assert_bash_profile_unset_dotfiles_dir_quiet
assert_bash_profile_idempotent

if command -v zsh >/dev/null 2>&1; then
  assert_zprofile_requires_zshrc
  assert_zprofile_loads_zshrc
  assert_zsh_profile_noninteractive_clean
  assert_zsh_profile_loads_modules
  assert_zsh_profile_applies_prompt
  assert_zsh_profile_invalid_dotfiles_dir_warns
  assert_zsh_profile_idempotent
else
  echo "SKIP: zsh is not installed"
fi

if [ "$failures" -gt 0 ]; then
  echo "Smoke test finished with $failures failure(s)." >&2
  exit 1
fi

echo "Smoke test: PASS"

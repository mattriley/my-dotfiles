#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/src/bash/script_common.sh"

dotfiles.setup_styles
dotfiles.parse_profile_args "Usage: $0 [--dry-run|--list|--plan] [--profile <name|all>]" 1 "$@"
parse_status=$?
[ "$parse_status" -eq 2 ] && exit 0
[ "$parse_status" -eq 0 ] || exit 1

function install_profile_file {
    local path="$1"
    local dest="$2"
    local base="$3"

    # Skip editor/system cruft so it doesn't get installed into $HOME
    [ "$base" = ".DS_Store" ] && return 0

    # shellcheck disable=SC2034
    DOTFILES_ITERATE_COUNTED=1

    if [ "$DRY_RUN" -eq 1 ]; then
        if [ "$LIST_ONLY" -eq 1 ]; then
            echo "LIST: ln -sfv \"$path\" \"$dest\""
        else
            echo "DRY RUN: ln -sfv \"$path\" \"$dest\""
        fi
        return 0
    fi

    mkdir -p "$(dirname "$dest")" || return 1
    ln -sfv "$path" "$dest"
}

function install_profiles {
    local profiles_dir="$SCRIPT_DIR/profiles"
    local status=0
    local profile_dir

    dotfiles.collect_profiles "$profiles_dir" "$PROFILE" || return 1

    for profile_dir in "${DOTFILES_PROFILES[@]}"; do
        dotfiles.sync_profile_files "$SCRIPT_DIR" "$profile_dir" "Installing" install_profile_file || status=1
    done

    return "$status"
}

echo
install_profiles
